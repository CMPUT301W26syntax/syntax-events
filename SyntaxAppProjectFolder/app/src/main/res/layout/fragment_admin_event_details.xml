<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_event_details_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Event Details"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_remove_event"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Remove Event"
        android:textAllCaps="false"
        android:textSize="12sp"
        android:textStyle="normal"
        android:textColor="#FF3B30"
        android:background="@drawable/rounded_red_outline_button"
        android:backgroundTint="@null"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/tv_detail_event_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Title: "
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_detail_event_description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Description: "
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_detail_event_organizer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Organizer: "
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_detail_event_location"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Location: "
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Event QR Code:"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <ImageView
        android:id="@+id/iv_event_qr_code"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="center_horizontal"
        android:scaleType="fitCenter" />

</LinearLayout>
