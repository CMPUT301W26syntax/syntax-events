<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="28dp"
    android:paddingTop="40dp"
    android:paddingEnd="28dp"
    android:background="#F7F3FA">

    <TextView
        android:id="@+id/tv_admin_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Admin Dashboard"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#222222"
        android:layout_marginBottom="28dp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_browse_events"
        android:layout_width="220dp"
        android:layout_height="48dp"
        android:text="Browse Events"
        android:textAllCaps="false"
        android:textSize="14sp"
        android:textStyle="normal"
        android:textColor="#000000"
        android:background="@drawable/rounded_black_button"
        android:backgroundTint="@null"
        android:layout_marginBottom="18dp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_browse_profiles"
        android:layout_width="220dp"
        android:layout_height="48dp"
        android:text="Browse Profiles"
        android:textAllCaps="false"
        android:textSize="14sp"
        android:textStyle="normal"
        android:textColor="#000000"
        android:background="@drawable/rounded_black_button"
        android:backgroundTint="@null"
        android:layout_marginBottom="18dp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_browse_images"
        android:layout_width="220dp"
        android:layout_height="48dp"
        android:text="Browse Images"
        android:textAllCaps="false"
        android:textSize="14sp"
        android:textStyle="normal"
        android:textColor="#000000"
        android:background="@drawable/rounded_black_button"
        android:backgroundTint="@null"
        android:layout_marginBottom="18dp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_notification_logs"
        android:layout_width="220dp"
        android:layout_height="48dp"
        android:text="Notification Logs"
        android:textAllCaps="false"
        android:textSize="14sp"
        android:textStyle="normal"
        android:textColor="#000000"
        android:background="@drawable/rounded_black_button"
        android:backgroundTint="@null" />

</LinearLayout>