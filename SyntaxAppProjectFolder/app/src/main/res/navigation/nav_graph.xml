<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.syntaxappproject.ui.SplashFragment"
        android:label="Splash">
        <action android:id="@+id/action_splash_to_profile" app:destination="@id/profileSetupFragment"/>
        <action android:id="@+id/action_splash_to_home" app:destination="@id/homeFragment"/>
    </fragment>

    <fragment
        android:id="@+id/profileSetupFragment"
        android:name="com.example.syntaxappproject.ui.ProfileSetupFragment"
        android:label="Profile Setup">
        <action android:id="@+id/action_profile_to_home" app:destination="@id/homeFragment"/>
        <action
            android:id="@+id/toUserFragmentFromSetup"
            app:destination="@id/userFragment"
            app:popUpTo="@id/userFragment"
            app:popUpToInclusive="true"/>
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.syntaxappproject.ui.HomeFragment"
        android:label="Home">
        <action android:id="@+id/toHomeFragment" app:destination="@id/homeFragment"/>
        <action android:id="@+id/toUserFragment" app:destination="@id/userFragment"/>
        <action android:id="@+id/toQrCodeScannerFragment" app:destination="@id/QRCodeScannerFragment"/>
        <action android:id="@+id/toNotificationFragment" app:destination="@id/notificationFragment"/>
        <action android:id="@+id/toOrganizerEventsFragment" app:destination="@id/organizerEventsFragment"/>
        <action android:id="@+id/toEventDetailFragment" app:destination="@id/eventDetailFragment"/>
    </fragment>

    <fragment
        android:id="@+id/userFragment"
        android:name="com.example.syntaxappproject.ui.UserFragment"
        android:label="User">
        <action android:id="@+id/toHomeFragment" app:destination="@id/homeFragment"/>
        <action android:id="@+id/toUserFragment" app:destination="@id/userFragment"/>
        <action android:id="@+id/toQrCodeScannerFragment" app:destination="@id/QRCodeScannerFragment"/>
        <action android:id="@+id/toNotificationFragment" app:destination="@id/notificationFragment"/>
        <action android:id="@+id/toOrganizerEventsFragment" app:destination="@id/organizerEventsFragment"/>
        <action android:id="@+id/editProfileFragment" app:destination="@id/editProfileFragment"/>
        <action android:id="@+id/eventHistoryFragment" app:destination="@id/eventHistoryFragment"/>
    </fragment>

    <fragment
        android:id="@+id/notificationFragment"
        android:name="com.example.syntaxappproject.ui.NotificationFragment"
        android:label="Notifications">
        <action android:id="@+id/toHomeFragment" app:destination="@id/homeFragment"/>
        <action android:id="@+id/toUserFragment" app:destination="@id/userFragment"/>
        <action android:id="@+id/toQrCodeScannerFragment" app:destination="@id/QRCodeScannerFragment"/>
        <action android:id="@+id/toNotificationFragment" app:destination="@id/notificationFragment"/>
        <action android:id="@+id/toOrganizerEventsFragment" app:destination="@id/organizerEventsFragment"/>
    </fragment>

    <fragment
        android:id="@+id/QRCodeScannerFragment"
        android:name="com.example.syntaxappproject.ui.QRCodeScannerFragment"
        android:label="QR Scanner">
        <action android:id="@+id/toHomeFragment" app:destination="@id/homeFragment"/>
        <action android:id="@+id/toUserFragment" app:destination="@id/userFragment"/>
        <action android:id="@+id/toQrCodeScannerFragment" app:destination="@id/QRCodeScannerFragment"/>
        <action android:id="@+id/toNotificationFragment" app:destination="@id/notificationFragment"/>
        <action android:id="@+id/toOrganizerEventsFragment" app:destination="@id/organizerEventsFragment"/>
        <action android:id="@+id/toEventDetailFragment" app:destination="@id/eventDetailFragment"/>
    </fragment>

    <fragment
        android:id="@+id/organizerEventsFragment"
        android:name="com.example.syntaxappproject.ui.OrganizerEventsFragment"
        android:label="My Events">
        <action android:id="@+id/toHomeFragment" app:destination="@id/homeFragment"/>
        <action android:id="@+id/toUserFragment" app:destination="@id/userFragment"/>
        <action android:id="@+id/toQrCodeScannerFragment" app:destination="@id/QRCodeScannerFragment"/>
        <action android:id="@+id/toNotificationFragment" app:destination="@id/notificationFragment"/>
        <action android:id="@+id/toOrganizerEventsFragment" app:destination="@id/organizerEventsFragment"/>
        <action android:id="@+id/toCreateEventFragment" app:destination="@id/createEventFragment"/>
        <action android:id="@+id/toEventDetailFragment" app:destination="@id/eventDetailFragment"/>
    </fragment>

    <fragment
        android:id="@+id/editProfileFragment"
        android:name="com.example.syntaxappproject.ui.EditProfileFragment"
        android:label="Edit Profile"
        tools:layout="@layout/fragment_user_edit">
        <action android:id="@+id/toHomeFragment" app:destination="@id/homeFragment"/>
        <action android:id="@+id/toUserFragment" app:destination="@id/userFragment"/>
        <action android:id="@+id/toQrCodeScannerFragment" app:destination="@id/QRCodeScannerFragment"/>
        <action android:id="@+id/toNotificationFragment" app:destination="@id/notificationFragment"/>
        <action android:id="@+id/toOrganizerEventsFragment" app:destination="@id/organizerEventsFragment"/>
        <action
            android:id="@+id/action_editProfileFragment_to_userFragment"
            app:destination="@id/userFragment"
            app:popUpTo="@id/userFragment"
            app:popUpToInclusive="true"/>
    </fragment>

    <fragment
        android:id="@+id/eventHistoryFragment"
        android:name="com.example.syntaxappproject.ui.EventHistoryFragment"
        android:label="Event History"
        tools:layout="@layout/fragment_event_history">
        <action android:id="@+id/toHomeFragment" app:destination="@id/homeFragment"/>
        <action android:id="@+id/toUserFragment" app:destination="@id/userFragment"/>
        <action android:id="@+id/toQrCodeScannerFragment" app:destination="@id/QRCodeScannerFragment"/>
        <action android:id="@+id/toNotificationFragment" app:destination="@id/notificationFragment"/>
        <action android:id="@+id/toOrganizerEventsFragment" app:destination="@id/organizerEventsFragment"/>
        <action android:id="@+id/toEventDetailFragment" app:destination="@id/eventDetailFragment"/>
    </fragment>

    <fragment
        android:id="@+id/eventDetailFragment"
        android:name="com.example.syntaxappproject.ui.EventDetailFragment"
        android:label="Event Detail">
        <argument android:name="eventId" app:argType="string"/>
        <action android:id="@+id/toHomeFragment" app:destination="@id/homeFragment"/>
        <action android:id="@+id/toUserFragment" app:destination="@id/userFragment"/>
        <action android:id="@+id/toQrCodeScannerFragment" app:destination="@id/QRCodeScannerFragment"/>
        <action android:id="@+id/toNotificationFragment" app:destination="@id/notificationFragment"/>
        <action android:id="@+id/toOrganizerEventsFragment" app:destination="@id/organizerEventsFragment"/>
    </fragment>

    <fragment
        android:id="@+id/createEventFragment"
        android:name="com.example.syntaxappproject.ui.CreateEventFragment"
        android:label="Create Event">
        <action android:id="@+id/toHomeFragment" app:destination="@id/homeFragment"/>
        <action android:id="@+id/toUserFragment" app:destination="@id/userFragment"/>
        <action android:id="@+id/toQrCodeScannerFragment" app:destination="@id/QRCodeScannerFragment"/>
        <action android:id="@+id/toNotificationFragment" app:destination="@id/notificationFragment"/>
        <action android:id="@+id/toOrganizerEventsFragment" app:destination="@id/organizerEventsFragment"/>
        <action android:id="@+id/toUploadImageFragment" app:destination="@id/createEventUploadPosterFragment"/>
    </fragment>

    <fragment
        android:id="@+id/createEventUploadPosterFragment"
        android:name="com.example.syntaxappproject.ui.CreateEventUploadPosterFragment"
        android:label="Upload Poster">
        <action android:id="@+id/toHomeFragment" app:destination="@id/homeFragment"/>
        <action android:id="@+id/toUserFragment" app:destination="@id/userFragment"/>
        <action android:id="@+id/toQrCodeScannerFragment" app:destination="@id/QRCodeScannerFragment"/>
        <action android:id="@+id/toNotificationFragment" app:destination="@id/notificationFragment"/>
        <action android:id="@+id/toOrganizerEventsFragment" app:destination="@id/organizerEventsFragment"/>
        <action android:id="@+id/toCreateEventQRFragment" app:destination="@id/CreateEventQRFragment"/>
    </fragment>

    <fragment
        android:id="@+id/CreateEventQRFragment"
        android:name="com.example.syntaxappproject.ui.CreateEventQRFragment"
        android:label="QR Step">
        <argument android:name="eventId" app:argType="string"/>
        <action
            android:id="@+id/action_createEventQRFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="false"/>
    </fragment>

</navigation>
