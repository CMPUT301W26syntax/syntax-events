<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    app:startDestination="@id/splashFragment"
    android:id="@+id/nav_graph">
    <!-- app:startDestination="@id/homeFragment"-->


    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.syntaxappproject.ui.SplashFragment"
        android:label="Splash">

        <action
            android:id="@+id/action_splash_to_profile"
            app:destination="@id/profileSetupFragment"/>
        <action
            android:id="@+id/action_splash_to_home"
            app:destination="@id/homeFragment"/>
        <action
            android:id="@+id/action_splash_to_admin"
            app:destination="@id/adminFragment" />
    </fragment>

    <fragment
        android:id="@+id/profileSetupFragment"
        android:name="com.example.syntaxappproject.ui.ProfileSetupFragment"
        android:label="Profile Setup">
        <action
            android:id="@+id/action_profile_to_home"
            app:destination="@id/homeFragment"/>
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.syntaxappproject.ui.HomeFragment"
        android:label="Home">
    <action
        android:id="@+id/toHomeFragment"
        app:destination="@id/homeFragment"/>
    <action
        android:id="@+id/toUserFragment"
        app:destination="@id/userFragment"/>
    <action
        android:id="@+id/toQrCodeScannerFragment"
        app:destination="@id/homeFragment"/>
    <action
        android:id="@+id/toNotificationFragment"
        app:destination="@id/homeFragment"/>
    </fragment>
    <fragment
        android:id="@+id/userFragment"
        android:name="com.example.syntaxappproject.ui.UserFragment"
        android:label="User">
        <action
            android:id="@+id/toHomeFragment"
            app:destination="@id/homeFragment"/>
        <action
            android:id="@+id/toUserFragment"
            app:destination="@id/userFragment"/>
        <action
            android:id="@+id/toQrCodeScannerFragment"
            app:destination="@id/homeFragment"/>
        <action
            android:id="@+id/toNotificationFragment"
            app:destination="@id/homeFragment"/>
    </fragment>

    <fragment
        android:id="@+id/adminFragment"
        android:name="com.example.syntaxappproject.AdminFragment"
        android:label="Admin"
        tools:layout="@layout/fragment_admin" />
    <fragment
        android:id="@+id/adminBrowseProfiles"
        android:name="com.example.syntaxappproject.AdminBrowseProfiles"
        android:label="Admin Browse Profiles"
        tools:layout="@layout/fragment_admin_browse_profiles" />
    <fragment
        android:id="@+id/adminProfileDetails"
        android:name="com.example.syntaxappproject.AdminProfileDetails"
        android:label="Profile Details"
        tools:layout="@layout/fragment_admin_profile_details" />
    <fragment
        android:id="@+id/adminBrowseEvents"
        android:name="com.example.syntaxappproject.AdminBrowseEvents"
        android:label="Admin Browse Events"
        tools:layout="@layout/fragment_admin_browse_events" />
    <fragment
        android:id="@+id/adminEventDetails"
        android:name="com.example.syntaxappproject.AdminEventDetails"
        android:label="Event Details"
        tools:layout="@layout/fragment_admin_event_details" />
    <fragment
        android:id="@+id/adminBrowseImages"
        android:name="com.example.syntaxappproject.AdminBrowseImages"
        android:label="Browse Images"
        tools:layout="@layout/fragment_admin_browse_images" />
    <fragment
        android:id="@+id/adminImageDetails"
        android:name="com.example.syntaxappproject.AdminImageDetails"
        android:label="Image Details"
        tools:layout="@layout/fragment_admin_image_details" />
</navigation>