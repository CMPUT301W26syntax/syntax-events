<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:startDestination="@id/homeFragment"
    android:id="@+id/nav_graph">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.syntaxappproject.ui.SplashFragment"
        android:label="Splash">
        <action
            android:id="@+id/action_splash_to_profile"
            app:destination="@id/profileSetupFragment"/>
        <action
            android:id="@+id/action_splash_to_home"
            app:destination="@id/homeFragment"/>
    </fragment>

    <fragment
        android:id="@+id/profileSetupFragment"
        android:name="com.example.syntaxappproject.ui.ProfileSetupFragment"
        android:label="Profile Setup">
        <action
            android:id="@+id/action_profile_to_home"
            app:destination="@id/homeFragment"/>
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.syntaxappproject.ui.HomeFragment"
        android:label="Home">
    <action
        android:id="@+id/toHomeFragment"
        app:destination="@id/homeFragment"/>
    <action
        android:id="@+id/toUserFragment"
        app:destination="@id/userFragment"/>
    <action
        android:id="@+id/toQrCodeScannerFragment"
        app:destination="@id/homeFragment"/>
    <action
        android:id="@+id/toNotificationFragment"
        app:destination="@id/homeFragment"/>
    </fragment>
    <fragment
        android:id="@+id/userFragment"
        android:name="com.example.syntaxappproject.ui.UserFragment"
        android:label="User">
        <action
            android:id="@+id/toHomeFragment"
            app:destination="@id/homeFragment"/>
        <action
            android:id="@+id/toUserFragment"
            app:destination="@id/userFragment"/>
        <action
            android:id="@+id/toQrCodeScannerFragment"
            app:destination="@id/homeFragment"/>
        <action
            android:id="@+id/toNotificationFragment"
            app:destination="@id/homeFragment"/>
    </fragment>

</navigation>